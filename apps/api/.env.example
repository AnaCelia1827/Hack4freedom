BLUEJET_ENV=development
DATABASE_URL=postgresql+psycopg://bluejet:change-me@localhost:5432/bluejet
DATABASE_LOCK_TIMEOUT_MS=1000
LIGHTNING_MODE=SANDBOX
CORS_ORIGINS=http://localhost:5173
NOSTR_AUTH_AUDIENCE=http://localhost:5173/api/auth/nostr/sessions
ADMIN_NOSTR_AUTH_AUDIENCE=http://localhost:5173/api/admin/auth/nostr/sessions
NOSTR_MAX_CLOCK_SKEW_SECONDS=300
NOSTR_MAX_AUTH_ATTEMPTS=5
DEMO_AUTH_ENABLED=false
DEMO_AUTH_PUBKEY=dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
# Development bootstrap without PostgreSQL. Database-backed roles come from user_roles.
BLUEJET_ADMIN_PUBKEYS=
