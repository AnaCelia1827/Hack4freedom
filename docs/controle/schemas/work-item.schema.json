{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluejet.local/schemas/work-item.schema.json",
  "title": "LARES WorkItem",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version", "id", "title", "objective", "state", "risk_class",
    "source_claims", "requirements", "dependencies", "affected_paths",
    "operations", "acceptance_criteria", "refutation_conditions", "recovery_strategy"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {"type": "string", "pattern": "^WI-[A-Z0-9-]+$"},
    "state": {
      "enum": ["CAPTURADO", "LASTREADO", "PRONTO", "EM_EXECUCAO", "EM_VERIFICACAO", "EM_VERIFICACAO_LOCAL", "BLOQUEADO", "EM_RISCO", "CANCELADO"]
    },
    "risk_class": {"enum": ["S0", "S1", "S2", "S3"]},
    "source_claims": {"type": "array", "items": {"type": "string", "pattern": "^CLM-"}, "uniqueItems": true},
    "requirements": {"type": "array", "items": {"type": "string", "pattern": "^(RF|RN|RNF|CA)-[0-9]{3}$"}, "uniqueItems": true},
    "dependencies": {"type": "array", "items": {"type": "string", "pattern": "^WI-"}, "uniqueItems": true},
    "affected_paths": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "operations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "authorization_id": {"type": ["string", "null"], "pattern": "^AUTH-"},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "refutation_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "recovery_strategy": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {"enum": ["CODE_ROLLBACK", "SCHEMA_FORWARD_FIX", "DATA_COMPENSATION", "PROVIDER_RECONCILIATION", "INCIDENT_CONTAINMENT", "REFUND_WORKFLOW", "IRREVERSIBLE"]},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^EV-"}, "uniqueItems": true}
  }
}
