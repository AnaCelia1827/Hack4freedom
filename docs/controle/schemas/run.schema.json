{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluejet.local/schemas/run.schema.json",
  "title": "LARES ExecutionRun",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version", "id", "work_item_id", "authorization_id", "started_at",
    "source_commit", "workspace_clean", "workspace_tree_hash", "commands", "result", "changed_paths"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {"type": "string", "pattern": "^RUN-"},
    "work_item_id": {"type": "string", "pattern": "^WI-"},
    "authorization_id": {"type": "string", "pattern": "^AUTH-"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "result_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "workspace_clean": {"type": "boolean"},
    "workspace_tree_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "patch_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commands": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "result": {"enum": ["PASS", "PASS_WITH_LIMITATIONS", "FAIL", "BLOCKED"]},
    "changed_paths": {"type": "array", "items": {"type": "string"}}
  }
}
